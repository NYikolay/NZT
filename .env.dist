# ── Environment ─────────────────────────────────────────────
ENVIRONMENT=local
# Options: local, staging, production

# ── Backend ──────────────────────────────────────────────────
SECRET_KEY=any_secret_key
# JWT signing secret. If not set, a random one is auto-generated.

BOT_SECRET_TOKEN=
# Telegram bot secret token for authentication (required).

PROJECT_TITLE=NZT - персональный ассистент для бизнеса
# Application title displayed in OpenAPI docs (required).

BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3001,http://localhost:3001,http://127.0.0.1:3000,http://localhost
# Comma-separated allowed CORS origins (required).

ALLOWED_HOSTS=*
# Comma-separated allowed host headers (required). Use "localhost,example.com" in production.

ACCESS_TOKEN_EXPIRE_MINUTES=11520
# JWT access token expiration in minutes. Default: 11520 (8 days).

# ── LLM / OpenRouter ────────────────────────────────────────
OPEN_ROUTER_API_KEY=
# API key for OpenRouter LLM gateway (required).

# ── Database (PostgreSQL) ────────────────────────────────────
POSTGRES_HOST=db
# PostgreSQL host (required).

POSTGRES_PORT=5432
# PostgreSQL port. Default: 5432.

POSTGRES_USER=nzt_user
# PostgreSQL user (required).

POSTGRES_PASSWORD=any_password
# PostgreSQL password (required).

POSTGRES_NAME=nzt_db
# PostgreSQL database name (required).

POSTGRES_POOL_SIZE=10
# Connection pool size. Default: 10.

POSTGRES_MAX_OVERFLOW=20
# Additional connections allowed beyond pool_size. Default: 20.

POSTGRES_POOL_RECYCLE=3600
# Recycle connections after this many seconds. Default: 3600 (1 hour).

POSTGRES_ECHO=false
# If true, emit SQL statements to logs. Default: false.

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
# Redis host (required).

REDIS_PORT=6379
# Redis port (required).

REDIS_DB=1
# Redis database number (required).

# ── NATS ─────────────────────────────────────────────────────
NATS_HOST=nats
# NATS host (required).

NATS_PORT=4222
# NATS port (required).

# ── Admin Panel ──────────────────────────────────────────────
ADMIN_USERNAME=admin
# Username for the SQLAdmin admin panel at /admin.

ADMIN_PASSWORD=admin
# Password for the SQLAdmin admin panel at /admin.

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
# Logging level. Options: DEBUG, INFO, WARNING, ERROR, CRITICAL (required).

LOG_FORMAT=json
# Log output format. Options: json, console (required).

LOG_FILE=logs/app.log
# Path to the log file (required).

LOG_ROTATION=DAILY
# Log rotation strategy. Options: DAILY, or size-based (required).